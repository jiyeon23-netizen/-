rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isVerifiedAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'jiyeon040223@gmail.com' && 
             request.auth.token.email_verified == true;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }

    // Validation
    function isValidSettings(data) {
      return data.keys().hasAll(['siteTitle', 'siteSubtitle']) &&
             data.siteTitle is string && data.siteTitle.size() <= 300 &&
             data.siteSubtitle is string && data.siteSubtitle.size() <= 300;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'category']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 300 &&
             data.category is string && data.category.size() <= 100;
    }

    function isValidArchive(data) {
      return data.keys().hasAll(['id', 'title']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 300;
    }

    // Collections
    match /settings/global {
      allow read: if true;
      allow write: if isVerifiedAdmin() && isValidSettings(incoming());
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isVerifiedAdmin() && isValidId(projectId) && isValidProject(incoming());
    }

    match /archive/{archiveId} {
      allow read: if true;
      allow write: if isVerifiedAdmin() && isValidId(archiveId) && isValidArchive(incoming());
    }
  }
}
